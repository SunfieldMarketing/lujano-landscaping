# GoHighLevel Configuration
# These are set as environment variables in Vercel dashboard

# GHL Form/Webhook URL - The webhook URL from your GoHighLevel workflow
# Used by forms to submit leads directly to GHL CRM
VITE_GHL_WEBHOOK_URL="https://services.leadconnectorhq.com/hooks/YOUR_WEBHOOK_ID"

# GHL Chat Widget ID (optional) - Embed the GHL chat widget
# Found in GoHighLevel > Sites > Chat Widget > Installation
VITE_GHL_CHAT_WIDGET_URL="https://widgets.leadconnectorhq.com/loader.js"
VITE_GHL_LOCATION_ID="YOUR_GHL_LOCATION_ID"
